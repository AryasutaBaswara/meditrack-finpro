{
  "realm": "meditrack",
  "enabled": true,
  "displayName": "MediTrack",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "accessTokenLifespan": 300,
  "refreshTokenMaxReuse": 0,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "admin",       "description": "Full system access" },
      { "name": "doctor",      "description": "Create prescriptions, view patients" },
      { "name": "pharmacist",  "description": "Process dispensations, manage stock" },
      { "name": "patient",     "description": "View own prescriptions only" }
    ]
  },
  "clients": [
    {
      "clientId": "meditrack-backend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "change-me-in-production",
      "bearerOnly": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8000/*"],
      "webOrigins": ["http://localhost:8000"]
    }
  ],
  "users": [
    {
      "username": "admin_user",
      "email": "admin@meditrack.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "realmRoles": ["admin"]
    },
    {
      "username": "doctor_user",
      "email": "doctor@meditrack.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "doctor123", "temporary": false }],
      "realmRoles": ["doctor"]
    },
    {
      "username": "pharmacist_user",
      "email": "pharmacist@meditrack.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "pharmacist123", "temporary": false }],
      "realmRoles": ["pharmacist"]
    },
    {
      "username": "patient_user",
      "email": "patient@meditrack.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "patient123", "temporary": false }],
      "realmRoles": ["patient"]
    }
  ]
}
