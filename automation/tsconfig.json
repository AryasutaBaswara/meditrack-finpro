{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"types": ["node", "@playwright/test"],
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"baseUrl": "."
	},
	"include": ["tests/**/*.ts", "playwright.config.ts"]
}
