# ─────────────────────────────────────────────────────────────
# MediTrack — .env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
APP_ENV=development                         # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=your-secret-key-here        # used for internal signing

# ── Supabase ──────────────────────────────────────────────────
# Use Supabase credentials for storage/auth integration.
# For local development, DATABASE_URL below points to Docker Postgres.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql+asyncpg://meditrack:meditrack@localhost:5433/meditrack

# ── Keycloak ──────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=meditrack
KEYCLOAK_CLIENT_ID=meditrack-backend
KEYCLOAK_CLIENT_SECRET=your-client-secret
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/meditrack/protocol/openid-connect/certs

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_DEFAULT=300                       # seconds — default cache TTL
REDIS_TTL_DRUG_LIST=600                     # seconds — drug list cache TTL

# ── Elasticsearch ─────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_DRUGS=meditrack_drugs
ELASTICSEARCH_USERNAME=elastic              # leave empty if no auth
ELASTICSEARCH_PASSWORD=your-es-password    # leave empty if no auth

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1000
OPENAI_TIMEOUT=30                           # seconds

# ── Supabase Storage ──────────────────────────────────────────
STORAGE_BUCKET_PRESCRIPTIONS=prescription-files
STORAGE_SIGNED_URL_EXPIRY=3600             # seconds — 1 hour

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100                    # requests per window
RATE_LIMIT_WINDOW=60                       # seconds

# ── Pagination Defaults ───────────────────────────────────────
PAGINATION_DEFAULT_PAGE_SIZE=20
PAGINATION_MAX_PAGE_SIZE=100

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Alembic ───────────────────────────────────────────────────
# Optional override for migrations. Keep this local by default.
# For staging/prod, set this to the Supabase Postgres URL for that environment.
ALEMBIC_DATABASE_URL=postgresql+asyncpg://meditrack:meditrack@localhost:5433/meditrack
